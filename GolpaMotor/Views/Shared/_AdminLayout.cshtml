@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap-5.3.8-dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="~/fonts/fontawesome-free-6.7.2-web/css/all.min.css" />
    <link rel="stylesheet" href="~/fonts/vazirmatn-master/Vazirmatn-font-face.css" />
    <link rel="stylesheet" href="~/css/AdminLayout.css" />
    <link href="~/lib/sweetalert2/sweetalert2.min.css" rel="stylesheet" />

    @RenderSection("Styles", false)

</head>

<body>
    <div class="d-flex">
        <partial name="_AdminSidebar" />

        <div class="main w-100">

            <partial name="_AdminHeader" />

            <div class="content p-4">

                @RenderBody()

            </div>

            <partial name="_AdminFooter" />

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap-5.3.8-dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/sweetalert2/sweetalert2.min.js"></script>

    @RenderSection("Scripts", false)

</body>

</html>