@model List<DomainModel.ViewModels.UserListItem>

<div class="main-card">

    <div class="p-4">

        <div class="section-title mb-3">
            <i class="fa fa-table text-primary"></i>
            لیست کاربران
        </div>

        <div class="table-responsive">

            <table class="table table-hover align-middle">

                <thead>

                    <tr>
                        <th>نام</th>
                        <th>نام خانوادگی</th>
                        <th>ایمیل</th>
                        <th>شماره موبایل</th>
                        <th>استان</th>
                        <th>شهر</th>
                        <th>تاریخ ثبت</th>
                        <th>جزئیات</th>
                        <th>ویرایش</th>
                        <th>حذف</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@item.FirstName</td>

                            <td>@item.LastName</td>

                            <td>@item.Email</td>

                            <td>@item.PhoneNumber</td>

                            <td>@item.Province</td>

                            <td>@item.City</td>

                            <td>
                                @item.RegisterDate.ToString("yyyy/MM/dd")
                            </td>

                            <td>

                                <button class="btn btn-sm btn-details"
                                        onclick="showDetails('@item.UserID')">

                                    <i class="fa fa-eye"></i>

                                </button>

                            </td>

                            <td>

                                <button class="btn btn-sm btn-edit"
                                        onclick="editUser('@item.UserID')">

                                    <i class="fa fa-pen"></i>

                                </button>

                            </td>

                            <td>

                                <button class="btn btn-sm btn-delete"
                                        onclick="deleteUser('@item.UserID')">

                                    <i class="fa fa-trash"></i>

                                </button>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>