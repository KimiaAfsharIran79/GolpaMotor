@{
    ViewData["Title"] = "پشتیبانی مشتریان";
}

<div class="support-page">

    <div class="support-card">

        <h2 class="support-title">
            پشتیبانی مشتریان
        </h2>

        <div class="support-info">

            <p>
                در صورت وجود هرگونه سوال، مشکل در ثبت گارانتی،
                پیگیری سفارش یا مسائل فنی می‌توانید از طریق
                سیستم تیکت با کارشناسان ما در ارتباط باشید.
            </p>

        </div>

        <div class="d-grid gap-3">

            <a asp-action="Create" class="btn btn-primary">
                ثبت تیکت جدید
            </a>

            <a asp-action="MyTickets" class="btn btn-outline-primary">  
                مشاهده تیکت های من
            </a>

        </div>

    </div>

</div>