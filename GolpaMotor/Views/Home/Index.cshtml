@{
    ViewData["Title"] = "خانه";
}

<!-- HERO -->
<section class="hero">

    <div class="container">

        <div class="row align-items-center">

            <div class="col-md-6 text-end">

                <h1 class="fw-bold">
                    فروش تخصصی لوازم یدکی خودرو
                </h1>

                <p class="text-muted">
                    کیفیت اصلی | قیمت مناسب | ارسال سریع به سراسر کشور
                </p>

                <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg">
                    مشاهده محصولات
                </a>

            </div>

            <div class="col-md-6 text-center">

                <img src="~/images/pics/hero-car.jpg" class="hero-img">

            </div>

        </div>

    </div>

</section>

<!-- CATEGORIES -->
<section class="container my-5">

    <h4 class="section-title">دسته‌بندی‌ها</h4>

    <div class="row g-3">

        <div class="col-6 col-md-3">
            <div class="category-card">سیستم ترمز</div>
        </div>

        <div class="col-6 col-md-3">
            <div class="category-card">موتور</div>
        </div>

        <div class="col-6 col-md-3">
            <div class="category-card">فیلترها</div>
        </div>

        <div class="col-6 col-md-3">
            <div class="category-card">تعلیق</div>
        </div>

    </div>

</section>

<!-- محصولات -->
<section class="container my-5">

    <h4 class="section-title">محصولات منتخب</h4>

    <div class="row g-3">

        <div class="col-6 col-md-3">
            <div class="product-card">
                <img src="~/images/pics/brake-pad.jpg">
                <h6>لنت ترمز پراید</h6>
                <small class="text-muted">ایساکو</small>
                <div class="price">850,000 تومان</div>
                <button class="btn btn-success w-100 mt-2"> افزودن به سبد </button>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="product-card">
                <img src="~/images/pics/alternator.jpg">
                <h6>  دینام</h6>
                <small class="text-muted">ایساکو</small>
                <div class="price">3,850,000 تومان</div>
                <button class="btn btn-success w-100 mt-2"> افزودن به سبد </button>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="product-card">
                <img src="~/images/pics/waterpump.jpg">
                <h6>واتر پمپ  </h6>
                <small class="text-muted">کروز</small>
                <div class="price">850,000 تومان</div>
                <button class="btn btn-success w-100 mt-2"> افزودن به سبد </button>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="product-card">
                <img src="~/images/pics/radiator.jpg">
                <h6>رادیاتور ال90</h6>
                <small class="text-muted">کروز</small>
                <div class="price">2,450,000 تومان</div>
                <button class="btn btn-success w-100 mt-2"> افزودن به سبد </button>

            </div>

        </div>

    </div>

</section>

<!-- FEATURES -->
<section class="features py-5">

    <div class="container text-center">

        <div class="row">

            <div class="col-md-4">
                🚚 ارسال سریع
            </div>

            <div class="col-md-4">
                🛡 ضمانت کالا
            </div>

            <div class="col-md-4">
                📞 پشتیبانی 24 ساعته
            </div>

        </div>

    </div>

</section>