@model GolpaMotor.Models.ViewModels.Account.LoginViewModel

@{
    ViewData["Title"] = "ورود";
}

<div class="auth-page">

    <div class="auth-card">

        <div class="auth-logo">
            <img src="~/images/pics/logo.png" alt="Golpa Motor" />
        </div>

        <h2 class="auth-title">فرم ورود</h2>

        <form asp-action="Login" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="auth-input-group">

                <label>  <i class="fa fa-envelope"></i>  ایمیل </label>

                <input asp-for="Email" class="form-control" placeholder="ایمیل خود را وارد کنید" />

                <span asp-validation-for="Email" class="text-danger"></span>

            </div>

            <div class="auth-input-group">

                <label>  <i class="fa fa-lock"></i>  رمز عبور  </label>

                <input asp-for="Password" type="password" class="form-control" placeholder="رمز عبور را وارد کنید" />

                <span asp-validation-for="Password" class="text-danger"></span>

            </div>

            <div class="auth-remember">

                <input asp-for="RememberMe" class="form-check-input" />

                <label asp-for="RememberMe"> مرا به خاطر بسپار </label>

            </div>

            <button type="submit" class="btn auth-btn"> ورود </button>

            <div class="auth-links">

                <a asp-action="ForgotPassword"> رمز عبورم را فراموش کرده‌ام </a>

            </div>

        </form>

    </div>

</div>